extends layout

block content
  h2 Редактирование игры: #{game.title}

  form(action=`/games/update/${game.gameid}` method="POST")
    .form-group
      label(for="title") Название:
      input.form-control(type="text" name="title" id="title" value=game.title required)

    .form-group
      label(for="price") Цена:
      input.form-control(type="number" step="0.01" name="price" id="price" value=game.price required)

    .form-group
      label(for="releasedate") Дата выхода:
      input.form-control(type="date" name="releasedate" id="releasedate" value=game.releasedate.toISOString().split('T')[0] required)

    .form-group
      label(for="developername") Издатель:
      input.form-control(type="text" name="developername" id="developername" value=game.developername required)

    .form-group
      label(for="image_url") Путь к изображению:
      input.form-control(type="text" name="image_url" id="image_url" value=game.image_url placeholder="/images/example.jpg")
      if game.image_url
        .current-image
          img(src=game.image_url alt="Текущее изображение" style="max-width: 200px; margin-top: 10px;")

    .form-actions
      button.btn.btn-primary(type="submit") Сохранить изменения
      a.btn.btn-secondary(href="/games" style="margin-left: 10px;") Отмена